{
  "name": "@harbourmesh/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "charts:nb:artifacts": "tsx src/generate-nb-chart-artifacts.ts",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.2",
    "geojson-vt": "^4.0.2",
    "pg": "^8.20.0",
    "sql.js": "^1.14.1",
    "vt-pbf": "^3.1.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/geojson-vt": "^3.2.5",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/sql.js": "^1.4.11",
    "@types/vt-pbf": "^3.1.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^3.0.5"
  }
}
